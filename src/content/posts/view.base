views:
  - type: table
    name: Table
    filters:
      and:
        - file.ext == "md"
    groupBy:
      property: category
      direction: ASC
    order:
      - title
      - published
      - draft
      - file.name
      - category
      - tags
      - description
    sort:
      - property: published
        direction: DESC
    columnSize:
      note.draft: 62
      file.name: 110
